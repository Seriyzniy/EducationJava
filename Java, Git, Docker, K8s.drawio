        <mxCell id="crQQvefYMBfLCh3Xmq8_-71" value="&lt;h3 data-end=&quot;1519&quot; data-start=&quot;1508&quot;&gt;Методы:&lt;/h3&gt;&lt;ul data-end=&quot;1636&quot; data-start=&quot;1520&quot;&gt;&lt;li data-end=&quot;1559&quot; data-start=&quot;1520&quot;&gt;&lt;p data-end=&quot;1559&quot; data-start=&quot;1522&quot;&gt;&lt;code data-end=&quot;1531&quot; data-start=&quot;1522&quot;&gt;await()&lt;/code&gt; — поток засыпает до сигнала&lt;/p&gt;&lt;/li&gt;&lt;li data-end=&quot;1596&quot; data-start=&quot;1560&quot;&gt;&lt;p data-end=&quot;1596&quot; data-start=&quot;1562&quot;&gt;&lt;code data-end=&quot;1572&quot; data-start=&quot;1562&quot;&gt;signal()&lt;/code&gt; — пробуждает один поток&lt;/p&gt;&lt;/li&gt;&lt;li data-end=&quot;1636&quot; data-start=&quot;1597&quot;&gt;&lt;p data-end=&quot;1636&quot; data-start=&quot;1599&quot;&gt;&lt;code data-end=&quot;1612&quot; data-start=&quot;1599&quot;&gt;signalAll()&lt;/code&gt; — пробуждает все потоки&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="1550" y="1265" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="crQQvefYMBfLCh3Xmq8_-72" value="Быстрая альтернатива &lt;code data-end=&quot;1725&quot; data-start=&quot;1710&quot;&gt;ReadWriteLock&lt;/code&gt;,&amp;nbsp;&lt;div&gt;использующая &lt;strong data-end=&quot;1757&quot; data-start=&quot;1740&quot;&gt;штампы (long)&lt;/strong&gt;.&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="1975" y="1185" width="250" height="40" as="geometry" />
