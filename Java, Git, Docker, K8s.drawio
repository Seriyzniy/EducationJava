        <mxCell id="crQQvefYMBfLCh3Xmq8_-70" value="Более гибкая альтернатива &lt;code data-end=&quot;1389&quot; data-start=&quot;1381&quot;&gt;wait()&lt;/code&gt;/&lt;code data-end=&quot;1400&quot; data-start=&quot;1390&quot;&gt;notify()&lt;/code&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
