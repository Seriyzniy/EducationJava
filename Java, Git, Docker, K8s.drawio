        <mxCell id="crQQvefYMBfLCh3Xmq8_-77" value="Поток ждёт, пока другие &lt;strong data-end=&quot;2448&quot; data-start=&quot;2435&quot;&gt;N потоков&lt;/strong&gt; не завершат свою работу." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
